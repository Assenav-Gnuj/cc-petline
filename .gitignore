/target

# Trademarked sprite assets (Octocat/Monamoji) — local only, never redistribute.
# Keep the dir structure + README/recipe, ignore the actual media.
/assets/source/*
!/assets/source/.gitkeep
!/assets/source/README.md
/assets/frames/*/*.png
# Custom theme sprite packs (sliced art) — keep structure, ignore the media.
/assets/themes/*/frames/*/*.png

# Plugin's copied binary (rebuild via plugin/build.ps1)
/plugin/bin/*.exe

# scratch/verification files
/.*.txt

# generated sprite preview images (regenerate via scripts/*.py)
/scripts/*.png
