/target

# Sprite frame media — local only, gitignored (regenerate via examples/slice.rs).
/assets/frames/*/*.png
# Custom theme sprite packs (sliced art) — keep structure, ignore the media.
/assets/themes/*/frames/*/*.png

# Plugin's copied binary (rebuild via plugin/build.ps1)
/plugin/bin/*.exe

# scratch/verification files
/.*.txt

# generated sprite preview images (regenerate via scripts/*.py)
/scripts/*.png
