{
  "SessionStart": [
    {
      "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" emit SessionStart" }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" emit UserPromptSubmit" }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "*",
      "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" emit PreToolUse" },
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" guard" }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "*",
      "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" emit PostToolUse" }
      ]
    }
  ],
  "Notification": [
    {
      "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" emit Notification" }
      ]
    }
  ],
  "SubagentStop": [
    {
      "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" emit SubagentStop" }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" emit Stop" }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" emit PreCompact" }
      ]
    }
  ],
  "SessionEnd": [
    {
      "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cc-petline.exe\" emit SessionEnd" }
      ]
    }
  ]
}
